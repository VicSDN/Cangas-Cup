---
import Layout from '../../../layouts/Layout2026.astro';
import Reglamento from '../../../components/user/2026/Reglamento.md';
---

<Layout
  title="Reglamento Oficial III Cangas Cup 2026 | Normas Fútbol Sala Asturias"
  description="📋 Reglamento oficial de la III Cangas Cup 2026. Normas, reglas y regulaciones del torneo de fútbol sala en Cangas del Narcea, Asturias. Conoce todas las bases del campeonato."
  keywords="reglamento cangas cup 2026, normas futsal, reglas futbol sala, bases torneo asturias"
  canonicalUrl="https://www.cangascup.es/user/2026/regulations"
>
  <main>
    <section class="text-gray-400 bg-blue-950 body-font mt-20">
      <div class="container mx-auto flex px-10 py-4 md:flex-col flex-col items-center mt-24">
        <a
          href="/reglamento2026.pdf"
          download="Reglamento_CangasCup_2026.pdf"
          class="inline-block bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded transition duration-300 ease-in-out mb-8"
        >
          Descargar Reglamento en PDF
        </a>
        <div class="text-center">
          <h1 class="text-4xl font-bold mb-4 text-center text-white">
            REGLAMENTO III CANGAS CUP FÚTBOL SALA 2026
          </h1>
          <Reglamento />
        </div>
        <a
          href="/reglamento2026.pdf"
          download="Reglamento_CangasCup_2026.pdf"
          class="inline-block bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded transition duration-300 ease-in-out mt-8"
        >
          Descargar Reglamento en PDF
        </a>
      </div>
    </section>
  </main>
</Layout>
